daily_distance = 10.0
total_distance_7_days = 0
print("Пробег по дням:")
for day in range(1, 11):
    if day == 1:
        total_distance_7_days += daily_distance
        print(f"день {day}: {daily_distance:.2f} км")
        continue
    daily_distance *= 1.10
    if day <= 7:
        total_distance_7_days += daily_distance
    print(f"День {day}: {daily_distance:.2f} км")
print(f"\n суммарный путь за первые 7 дней: {total_distance_7_days:.2f} км")
